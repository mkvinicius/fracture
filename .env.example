# FRACTURE — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# ─── LLM (obrigatório para simulações completas) ───────
# Anthropic (recomendado)
LLM_API_KEY=sk-ant-...
LLM_BASE_URL=https://api.anthropic.com
LLM_MODEL_NAME=claude-sonnet-4-20250514

# OpenAI (alternativa)
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com
# LLM_MODEL_NAME=gpt-4o

# Modelo para tarefas rotineiras (opcional — usa LLM_MODEL_NAME se omitido)
# LLM_ROUTINE_MODEL=claude-haiku-4-20250514

# ─── BUSCA WEB (opcional) ──────────────────────────────
# Tavily (recomendado — melhores resultados para DeepSearch)
TAVILY_API_KEY=tvly-...

# SerpAPI (alternativa)
# SERPAPI_KEY=...

# Sem chave: DuckDuckGo gratuito (resultados limitados)

# ─── SERVIDOR (opcional) ───────────────────────────────
# Porta do servidor (padrão: 8080)
# PORT=8080

# ─── SEGURANÇA (recomendado em produção) ───────────────
# Chave HMAC para audit log
# FRACTURE_HMAC_SECRET=sua-chave-secreta-aqui

# ─── ATUALIZAÇÕES (opcional) ───────────────────────────
# Desabilitar verificação automática de updates
# DISABLE_UPDATE_CHECK=true
